# Database
DB_TYPE=sqlite
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_DATABASE=anime_player

# JWT
JWT_SECRET=your_jwt_secret_here_change_me
JWT_EXPIRES_IN=7d

# Firebase (for push notifications)
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_DATABASE_URL=https://your-project.firebasedatabase.app

# App
PORT=3005
NODE_ENV=development

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# External APIs
CONSUMET_API_URL=http://localhost:3004
JIKAN_API_URL=https://api.jikan.moe/v4
MANGAHOOK_API_URL=https://mangahook-api.vercel.app/api
MANGADEX_API_URL=https://api.mangadex.org

# Cache TTLs (seconds)
JIKAN_CACHE_TTL=86400
MANGAHOOK_CACHE_TTL=3600
MANGADEX_CACHE_TTL=21600

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_PREMIUM_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# TMDB API (required for movies/TV)
TMDB_API_KEY=

# AI (optional)
PERPLEXITY_API_KEY=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
